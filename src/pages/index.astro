---
import BaseLayout from '../layouts/BaseLayout.astro';
import { hierarchy } from '../lib/hierarchy';
import { SECTOR_COLORS } from '../lib/api';

let totalPrimary = 0;
for (const s of hierarchy.六大板块) totalPrimary += s.一级数量;
let totalSecondary = 0;
for (const s of hierarchy.六大板块) {
  for (const p of s.children) totalSecondary += p.children.length;
}

const sectorColors = SECTOR_COLORS;
---

<BaseLayout>
  <header class="app-header">
    <div class="app-header-inner">
      <div class="app-logo">
        <div class="app-logo-icon">SW</div>
        <div>
          <div class="app-title">申万行业 <span>行情</span></div>
          <div class="app-subtitle">实时数据看板</div>
        </div>
      </div>
      <div class="header-time" id="headerTime"></div>
    </div>
  </header>

  <main class="app-main">
    <nav class="tab-nav" role="tablist">
      <button class="tab-btn active" data-tab="sector" role="tab">六大风格 <span class="count">6</span></button>
      <button class="tab-btn" data-tab="primary" role="tab">一级行业 <span class="count">{totalPrimary}</span></button>
      <button class="tab-btn" data-tab="secondary" role="tab">二级行业 <span class="count">{totalSecondary}</span></button>
    </nav>

    <section class="panel active" id="panelSector" role="tabpanel">
      <div class="sector-grid" id="sectorGrid"><div class="loading"><div class="spinner"></div><div class="loading-text">加载中</div></div></div>
    </section>

    <section class="panel" id="panelPrimary" role="tabpanel">
      <div class="search-bar"><span class="search-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span><input class="search-input" type="text" id="primarySearch" placeholder="搜索一级行业..." /></div>
      <div id="primaryContent"><div class="loading"><div class="spinner"></div><div class="loading-text">加载中</div></div></div>
    </section>

    <section class="panel" id="panelSecondary" role="tabpanel">
      <div class="search-bar"><span class="search-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span><input class="search-input" type="text" id="secondarySearch" placeholder="搜索二级行业..." /></div>
      <div id="secondaryContent"><div class="loading"><div class="spinner"></div><div class="loading-text">加载中</div></div></div>
    </section>
  </main>

  <footer class="app-footer">
    申万宏源指数 · <a href="https://github.com/akfamily/akshare" target="_blank" rel="noopener">akshare</a>
    · <a href="https://github.com/MORECORIANDERS/sw-industry-dashboard" target="_blank" rel="noopener">GitHub</a>
  </footer>

  <div class="last-update" id="lastUpdate"></div>

  <script id="boot-data" type="application/json" set:html={JSON.stringify({ hierarchy, sectorColors })}></script>

  <script>
  import { formatPrice, formatChange } from '../lib/api';

  const BOOT = JSON.parse(document.getElementById('boot-data').textContent);
  const HIERARCHY = BOOT.hierarchy;
  const COLORS = BOOT.sectorColors;

  function showError(containerId, msg) {
    const container = document.getElementById(containerId);
    if (!container) return;
    container.innerHTML = `<div class="error-state"><div class="icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div><div class="msg">${msg}</div><div class="hint">数据将在交易日盘后更新，请稍后再来</div><button class="retry-btn" onclick="location.reload()">重新加载</button></div>`;
  }

  // clock
  function updateClock() {
    document.getElementById('headerTime').textContent = new Date().toLocaleString('zh-CN', { hour12: false, hour: '2-digit', minute: '2-digit' });
  }
  updateClock();
  setInterval(updateClock, 1000);

  // tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      const tab = btn.dataset.tab;
      document.getElementById('panel' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
    });
  });

  // search
  document.getElementById('primarySearch').addEventListener('input', function () {
    const q = this.value.trim();
    document.querySelectorAll('#primaryContent .industry-sector-group').forEach(g => {
      let visible = false;
      g.querySelectorAll('.industry-card').forEach(c => {
        const match = !q || c.querySelector('.industry-name').textContent.includes(q);
        c.style.display = match ? '' : 'none';
        if (match) visible = true;
      });
      g.style.display = visible || !q ? '' : 'none';
    });
  });

  document.getElementById('secondarySearch').addEventListener('input', function () {
    const q = this.value.trim();
    document.querySelectorAll('#secondaryContent .secondary-group').forEach(g => {
      let visible = false;
      g.querySelectorAll('.secondary-item').forEach(item => {
        const match = !q || item.querySelector('.secondary-item-name').textContent.includes(q);
        item.style.display = match ? '' : 'none';
        if (match) visible = true;
      });
      g.style.display = visible || !q ? '' : 'none';
    });
  });

  // render sector cards
  function renderSectors(data) {
    const grid = document.getElementById('sectorGrid');
    const map = {};
    data.forEach(item => { map[item['指数名称']] = item; });
    let html = '';
    HIERARCHY['六大板块'].forEach(s => {
      const d = map[s['板块']] || {};
      const c = formatChange(d['涨跌幅']);
      const color = COLORS[s['板块']] || '#666';
      html += '<div class="sector-card" style="--sector-color:' + color + '">'
        + '<div class="sector-card-header"><div class="sector-name">' + s['板块'] + '</div>'
        + '<div class="sector-index-code">' + (d['指数代码'] || '--') + '</div></div>'
        + '<div class="sector-price-area"><span class="sector-price">' + formatPrice(d['最新价']) + '</span>'
        + '<span class="sector-change ' + c.cls + '">' + c.text + '</span></div>'
        + '<div class="sector-details">'
        + '<span><span class="label">开</span>' + formatPrice(d['今开盘']) + '</span>'
        + '<span><span class="label">高</span>' + formatPrice(d['最高价']) + '</span>'
        + '<span><span class="label">低</span>' + formatPrice(d['最低价']) + '</span>'
        + '<span><span class="label">量</span>' + (d['成交量'] || '--') + '</span>'
        + '<span><span class="label">额</span>' + (d['成交额'] || '--') + '</span>'
        + '</div></div>';
    });
    grid.innerHTML = html;
  }

  // render primary industries
  function renderPrimary(data) {
    const container = document.getElementById('primaryContent');
    const map = {};
    data.forEach(item => { map[item['指数名称']] = item; });
    let html = '';
    HIERARCHY['六大板块'].forEach(s => {
      const color = COLORS[s['板块']] || '#666';
      html += '<div class="industry-sector-group">'
        + '<div class="industry-sector-header">'
        + '<span class="industry-sector-dot" style="background:' + color + '"></span>'
        + '<span class="industry-sector-title">' + s['板块'] + '</span>'
        + '<span class="industry-sector-count">' + s['一级数量'] + ' 个一级行业</span>'
        + '</div><div class="industry-grid">';
      s.children.forEach(p => {
        const d = map[p.name] || {};
        const c = formatChange(d['涨跌幅']);
        html += '<div class="industry-card">'
          + '<span class="industry-name">' + p.name + '</span>'
          + '<div style="display:flex;align-items:center;gap:6px">'
          + '<span class="industry-price">' + formatPrice(d['最新价']) + '</span>'
          + '<span class="industry-change ' + c.cls + '">' + c.text + '</span>'
          + '</div></div>';
      });
      html += '</div></div>';
    });
    container.innerHTML = html;
  }

  // render secondary industries
  function renderSecondary(data) {
    const container = document.getElementById('secondaryContent');
    const map = {};
    data.forEach(item => { map[item['指数名称']] = item; });
    let html = '';
    HIERARCHY['六大板块'].forEach(s => {
      s.children.forEach(p => {
        const kids = p.children;
        if (!kids.length) return;
        html += '<div class="secondary-group">'
          + '<div class="secondary-group-header" onclick="var b=this.nextElementSibling;b.classList.toggle(\'open\');this.querySelector(\'.secondary-group-arrow\').classList.toggle(\'open\')">'
          + '<span class="secondary-group-arrow open">&#9654;</span>'
          + '<span class="secondary-group-title">' + p.name + '</span>'
          + '<span class="secondary-group-count">' + kids.length + ' 个二级行业</span>'
          + '</div>'
          + '<div class="secondary-group-body open">';
        kids.forEach(k => {
          const d = map[k.name] || {};
          const c = formatChange(d['涨跌幅']);
          html += '<div class="secondary-item">'
            + '<span class="secondary-item-name">' + k.name + '</span>'
            + '<span class="secondary-item-price">' + formatPrice(d['最新价']) + '</span>'
            + '<span class="secondary-item-change ' + c.cls + '">' + c.text + '</span>'
            + '</div>';
        });
        html += '</div></div>';
      });
    });
    container.innerHTML = html;
  }

  // fetch static market data JSON
  async function loadAll() {
    try {
      const res = await fetch(import.meta.env.BASE_URL + 'data/market-data.json');
      if (!res.ok) throw new Error(`加载失败 (${res.status})`);
      const json = await res.json();
      document.getElementById('lastUpdate').textContent = '更新于 ' + (json.updated_at || '--');
      if (json.sector && json.sector.length) renderSectors(json.sector);
      if (json.primary && json.primary.length) renderPrimary(json.primary);
      if (json.secondary && json.secondary.length) renderSecondary(json.secondary);
    } catch (err) {
      const msg = err.message;
      showError('sectorGrid', msg);
      showError('primaryContent', msg);
      showError('secondaryContent', msg);
    }
  }

  loadAll();
  </script>
</BaseLayout>
